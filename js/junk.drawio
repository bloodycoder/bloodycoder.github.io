        <mxCell id="VKr-EImMsc7NlC5uQBsD-42" value="两种情况" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="440" y="150" width="75" height="20" as="geometry" />
